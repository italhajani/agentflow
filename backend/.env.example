# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AgentFlow
APP_VERSION=1.0.0
DEBUG=true
FRONTEND_URL=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev — switch to PostgreSQL (Supabase) for production
DATABASE_URL=sqlite:///./agentflow.db
# DATABASE_URL=postgresql://user:password@host:5432/agentflow

# ── Redis (task queue) ────────────────────────────────────────────────────────
# Use Upstash free tier for production
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://:password@your-upstash-url:6380

# ── AI Models (all free tiers) ────────────────────────────────────────────────
# Groq — free tier, very fast (llama3, mixtral)
# Get key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# HuggingFace — free inference API
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-hf-api-key

# Google Gemini — free tier (generous limits)
# Get key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Vector DB ─────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Free tier: max runs per user per day
FREE_TIER_DAILY_RUNS=10
MAX_TASK_TIMEOUT_SECONDS=120
